    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "iron-session": "^8.0.4",
    "marked": "^18.0.4",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "sonner": "^2.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260522.1",
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "lefthook": "^2.1.8",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.93.1"
  },
  "ignoreScripts": [
    "sharp",
