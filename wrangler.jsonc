{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "projectblue-cc",
  "main": "src/index.js",
  "compatibility_date": "2026-05-14",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  }
}
